# ----- Required -----
# MongoDB Atlas connection string (Database Deployments → Connect → Drivers → Python)
MONGO_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority

# Database name inside the cluster (free-form; the app creates it on first write)
DB_NAME=realtorspal

# JWT signing secret — generate a fresh 64-char random string (e.g. `python -c "import secrets; print(secrets.token_urlsafe(48))"`)
JWT_SECRET_KEY=change-me-to-a-long-random-string

# Comma-separated list of allowed CORS origins (your Vercel URLs, no trailing slash)
# Example: https://realtorspal-crm.vercel.app,https://realtorspal-marketing.vercel.app
CORS_ORIGINS=http://localhost:3000

# Public URL the backend advertises in its startup log (informational only)
REACT_APP_BACKEND_URL=http://localhost:8001

# ----- Optional (feature-gated) -----
# Emergent-hosted LLM key; used as fallback if a user has not provided their own OpenAI key
EMERGENT_LLM_KEY=

# Twilio (voice + SMS + WhatsApp)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_TWIML_APP_SID=
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=

# SendGrid (outbound email)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# Logging
LOG_LEVEL=info
